# Windows Copilot API — environment configuration
# Copy to .env and adjust as needed.

# Enterprise (Microsoft 365 Copilot) account:
#   COPILOT_URL=https://m365.cloud.microsoft
# Consumer (personal) account:
#   COPILOT_URL=https://copilot.microsoft.com
COPILOT_URL=https://m365.cloud.microsoft

# API key for authenticating requests (Bearer token).
# Serves as a "bootstrap" key that always works.
# Additional keys can be created at runtime via the admin API (no restart needed).
# Set to "auto" to generate a random key on startup (printed to stderr).
# Leave empty to rely solely on admin-managed keys (or disable auth if none exist).
API_KEY=

# Admin key for /admin/* management endpoints (key CRUD).
# Set to "auto" to generate a random admin key on startup (printed to stderr).
# Leave empty to disable admin endpoints entirely (returns 404).
ADMIN_KEY=auto

# Rate limiting (self-imposed, Copilot publishes none)
RATE_LIMIT_RPM=12
RATE_LIMIT_BURST=4
