# Windows Copilot API — environment configuration
# Copy to .env and adjust as needed.

# Enterprise (Microsoft 365 Copilot) account:
#   COPILOT_URL=https://m365.cloud.microsoft
# Consumer (personal) account:
#   COPILOT_URL=https://copilot.microsoft.com
COPILOT_URL=https://m365.cloud.microsoft

# API key for authenticating requests (Bearer token).
# When set, all /v1/* endpoints require "Authorization: Bearer <key>".
# Set to "auto" to generate a random key on startup (printed to stderr).
# Leave empty to disable auth (not recommended for production).
API_KEY=

# Rate limiting (self-imposed, Copilot publishes none)
RATE_LIMIT_RPM=12
RATE_LIMIT_BURST=4
